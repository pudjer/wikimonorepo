{
  "name": "backend",
  "version": "1.0.0",
  "description": "Structured Wiki with Neo4j and Elasticsearch",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main/index.js",
    "dev": "nest start --watch src/main/index.ts",
    "start:debug": "node --inspect-brk node_modules/ts-node/dist/bin.js src/main/index.ts",
    "start:nest": "nest start",
    "start:dev": "nest start --watch"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.12.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.0.0",
    "@types/joi": "^17.2.2",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.0.0",
    "express": "^5.2.1",
    "joi": "^18.0.2",
    "neo4j-driver": "^5.15.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
